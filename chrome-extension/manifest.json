{
  "manifest_version": 3,
  "name": "MAWM Glean Session Bridge",
  "version": "2.0.0",
  "description": "Bridges the MAWM Fragment Designer / Agent Creator web app to Glean using your own authenticated browser session. Your cookie value never leaves your browser — the extension calls Glean directly and relays the result.",
  "key": "",

  "permissions": ["cookies"],
  "host_permissions": [
    "*://*.glean.com/*"
  ],

  "externally_connectable": {
    "matches": [
      "http://localhost:8000/*",
      "http://localhost:5173/*",
      "http://localhost:5174/*",
      "http://10.50.78.184:8000/*",
      "http://alvb-mausrhel7001:8000/*"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "MAWM Glean Session Bridge"
  },

  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
